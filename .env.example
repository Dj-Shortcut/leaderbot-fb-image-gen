# ------------------------------------------------------------
# Core required (startup checks)
# ------------------------------------------------------------
# Required: used to sign admin JWT cookies; must be at least 32 chars.
JWT_SECRET=replace_with_at_least_32_char_random_secret
# Required: used for pseudonymous user-key hashing.
PRIVACY_PEPPER=replace_with_long_random_secret

# ------------------------------------------------------------
# Facebook Messenger webhook/app credentials
# ------------------------------------------------------------
# Required for webhook verification challenge.
FB_VERIFY_TOKEN=replace_with_verify_token
# Optional preferred generic Meta webhook verification token.
# If set, this is used for both Messenger and WhatsApp callback verification.
META_VERIFY_TOKEN=
# Required for sending Messenger responses.
FB_PAGE_ACCESS_TOKEN=replace_with_page_access_token
# Required for canonical /play/{variantId} share redirects to m.me.
MESSENGER_PAGE_ID=replace_with_page_id
# Required for webhook signature verification.
FB_APP_SECRET=replace_with_app_secret
# Required for Facebook sharing debugger/Open Graph ownership (fb:app_id).
FB_APP_ID=replace_with_facebook_app_id
# Required for WhatsApp Cloud API sends.
WHATSAPP_ACCESS_TOKEN=replace_with_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_whatsapp_phone_number_id

# Required for inbound source-image fetching allowlist.
# If unset/empty, source-image fetches fail closed.
# Security: regularly review this list and keep only exact trusted hostnames.
SOURCE_IMAGE_ALLOWED_HOSTS=scontent.xx.fbcdn.net,lookaside.fbsbx.com

# ------------------------------------------------------------
# Image generation
# ------------------------------------------------------------
# Required: public absolute base URL for generated image URLs.
# Security: this must be HTTPS in production.
APP_BASE_URL=http://localhost:3000
# Required for image generation.
OPENAI_API_KEY=replace_with_openai_api_key

# Optional timeouts/retries that strongly affect generation behavior.
OPENAI_IMAGE_TIMEOUT_MS=30000
FB_IMAGE_FETCH_TIMEOUT_MS=10000
OPENAI_IMAGE_MAX_RETRIES=1
OPENAI_IMAGE_RETRY_BASE_MS=500

# ------------------------------------------------------------
# Redis-backed protections and limits
# ------------------------------------------------------------
# Required in production (NODE_ENV=production) for webhook replay protection.
# Optional in development; also enables Redis-backed HTTP rate limiting.
REDIS_URL=redis://localhost:6379
# Optional: replay-protection TTL in seconds (default 300).
WEBHOOK_REPLAY_TTL_SECONDS=300
# Optional: global HTTP rate-limit window (default 60000 ms).
HTTP_RATE_LIMIT_WINDOW_MS=60000
# Optional: max requests per IP per window (default 120).
HTTP_RATE_LIMIT_MAX_REQUESTS=120

# ------------------------------------------------------------
# Admin/debug and server behavior
# ------------------------------------------------------------
# Optional: protects GET /debug/build via X-Admin-Token.
ADMIN_TOKEN=
# Optional: server port (default 8080).
PORT=8080
# Optional: set to production to enforce production-only checks.
NODE_ENV=development

# Optional diagnostics.
LOG_LEVEL=info
DEBUG_STATE_DUMP=0
DEBUG_IMAGE_PROOF=0

# Optional Messenger behavior tuning.
DEFAULT_MESSENGER_LANG=nl
PRIVACY_POLICY_URL=
MESSENGER_MAX_IMAGE_JOBS=3
MESSENGER_PSID_COOLDOWN_MS=0
MESSENGER_PSID_LOCK_TTL_MS=120000
GRAPH_API_MAX_RETRIES=1
GRAPH_API_RETRY_BASE_MS=500
# Optional Messenger text brain rollout (phase 1 uses legacy by default).
MESSENGER_CHAT_ENGINE=legacy
MESSENGER_CHAT_CANARY_PERCENT=0
OPENAI_TEXT_MODEL=gpt-4.1-mini
MESSENGER_CHAT_HISTORY_LIMIT=12
MESSENGER_CHAT_HISTORY_TTL_SECONDS=604800
OPENAI_TEXT_TIMEOUT_MS=12000
OPENAI_TEXT_MAX_RETRIES=1

# Optional: bypass daily Messenger quota for these IDs (comma-separated PSIDs or hashed userKeys).
MESSENGER_QUOTA_BYPASS_IDS=
# Optional: ask Messenger users for explicit 30-day photo reuse consent.
ENABLE_FACE_MEMORY=false

# Optional: enables /api/chat when both variables are set
# ------------------------------------------------------------
# Optional GitHub admin OAuth (enables /admin auth flow when all are set)
# ------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
ADMIN_GITHUB_USERS=

# ------------------------------------------------------------
# Optional OAuth/data integration vars used by server/_core/env.ts
# ------------------------------------------------------------
VITE_APP_ID=
DATABASE_URL=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
# Production image storage proxy base URL, for example:
# https://leaderbot-storage-proxy.fly.dev
BUILT_IN_FORGE_API_URL=
# Bearer token shared with the storage proxy (FORGE_API_KEY on the proxy side).
BUILT_IN_FORGE_API_KEY=
# Optional: the public asset base returned by the storage proxy. Set this in the
# main app too if the public URL has a path prefix, so deletion can derive R2 keys.
PUBLIC_BASE_URL=
