{
  "name": "leaderbot-fb-image-gen",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js",
    "build:docker": "vite build && esbuild server/_core/index.ts --platform=node --bundle --format=cjs --external:vite --outfile=dist/index.cjs",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "deploy:check-docker": "node scripts/check-docker-host.mjs",
    "fallow": "npx --yes fallow@2.27.0 --root .",
    "fallow:list": "npx --yes fallow@2.27.0 --root . list",
    "fallow:production": "npx --yes fallow@2.27.0 --root . --production",
    "fallow:report": "npx --yes fallow@2.27.0 --root . -f json > .fallow/report.json",
    "fallow:report:production": "npx --yes fallow@2.27.0 --root . --production -f json > .fallow/report-production.json",
    "fallow:summary": "npx --yes fallow@2.27.0 --root . --summary --score",
    "fallow:gate": "node scripts/check-fallow-gate.mjs .fallow/report.json",
    "fix:docker": "scripts\\fix-docker.cmd",
    "format": "prettier --write .",
    "lint": "eslint client/src shared",
    "lint:fix": "eslint client/src shared --fix",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "vitest run",
    "lint:server": "eslint server",
    "lint:server:fix": "eslint server --fix",
    "storage-proxy:dev": "tsx watch storage-proxy/index.ts",
    "storage-proxy:start": "cross-env NODE_ENV=production tsx storage-proxy/index.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "ai": "^6.0.38",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "8.2.2",
    "ioredis": "^5.10.0",
    "jose": "6.1.0",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.15.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "superjson": "^1.13.3",
    "tailwind-merge": "^3.5.0",
    "wouter": "3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@eslint/js": "^9.36.0",
    "vitest": "^4.1.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "vite-plugin-manus-runtime": "^0.0.57",
    "vite": "^8.0.8",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "typescript-eslint": "^8.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "tailwindcss>nanoid": "3.3.7",
      "fast-xml-parser": "^5.3.5",
      "lodash": "^4.17.23",
      "lodash-es": "^4.17.23",
      "qs": "^6.14.2"
    }
  }
}
