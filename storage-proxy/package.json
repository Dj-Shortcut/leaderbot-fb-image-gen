{
  "name": "leaderbot-storage-proxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:proxy": "esbuild index.ts --platform=node --target=node20 --bundle --format=esm --outfile=dist/index.js",
    "start:proxy": "tsx index.ts",
    "start:proxy:dist": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "dotenv": "^17.2.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.4.1"
}
